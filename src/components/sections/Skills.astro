---
import Container from "../ui/Container.astro";
import { skillsContent } from "../../data/skills";

const languageBarToneClass = {
	muted: "bg-border/70",
	gold: "bg-gold/85",
	primary: "bg-primary/85"
} as const;
---

<section id="habilidades" class="bg-bg pb-20 pt-14 sm:pb-24 sm:pt-16 lg:pb-28 lg:pt-20" data-reveal="up">
	<Container class="lg:px-12 xl:px-16">
		<div class="grid items-start gap-10 lg:grid-cols-[1fr_0.95fr] lg:gap-12">
			<div>
				<header>
					<h2 class="text-[1.65rem] leading-none text-ink sm:text-[2.05rem]">{skillsContent.title}</h2>
					<div class="mt-3 h-[0.0625rem] w-20 bg-gold/80"></div>
				</header>

				<div class="mt-8">
					<p class="text-[0.62rem] font-medium tracking-[0.35em] sm:text-[0.68rem]">
						{skillsContent.expertiseLabel}
					</p>
					<ul class="mt-5 flex flex-wrap gap-3">
						{
							skillsContent.expertise.map((item) => (
								<li class="rounded-pill border border-border/90 px-5 py-2 text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-muted transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/40 hover:text-ink sm:px-6 sm:text-[0.68rem]">
									{item}
								</li>
							))
						}
					</ul>
				</div>

				<div class="mt-10 sm:mt-12">
					<p class="text-[0.62rem] font-medium tracking-[0.35em] sm:text-[0.68rem]">
						{skillsContent.languagesLabel}
					</p>
					<ul class="mt-6 space-y-5">
						{
							skillsContent.languages.map((language) => (
								<li class="group grid items-center gap-4 sm:grid-cols-[12.5rem_1fr] sm:gap-6">
									<p class="font-serif text-[1.25rem] italic leading-none text-ink sm:text-[1.45rem]">
										{language.label}
									</p>
									<span
										class:list={[
											"h-[0.0625rem] w-full transition-opacity duration-300 group-hover:opacity-75",
											languageBarToneClass[language.tone]
										]}
									></span>
								</li>
							))
						}
					</ul>
				</div>
			</div>

			<div class="border border-border/80 bg-surface p-8 transition-all duration-500 hover:-translate-y-1 hover:border-border hover:shadow-soft sm:p-10 lg:p-12">
				<h3 class="text-[1.7rem] leading-none text-ink sm:text-[2.05rem]">
					{skillsContent.educationTitle}
				</h3>

				<ul class="mt-8 space-y-8 sm:mt-10 sm:space-y-10">
					{
						skillsContent.education.map((item) => (
							<li>
								<p class="text-[1.35rem] leading-tight text-ink sm:text-[1.55rem]">{item.title}</p>
								<p class="mt-2 text-[0.62rem] font-medium tracking-[0.14em] text-gold sm:text-[0.68rem]">
									{item.meta}
								</p>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</Container>
</section>
