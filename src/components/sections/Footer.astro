---
import Container from "../ui/Container.astro";
import { footerContent } from "../../data/footer";
---

<footer class="bg-white pb-16 pt-14 sm:pb-20 sm:pt-16 lg:pb-24 lg:pt-20" data-reveal="up">
	<Container class="lg:px-12 xl:px-16">
		<div class="mx-auto max-w-[42rem] text-center">
			<p class="font-serif text-[1.55rem] tracking-[0.35em] text-ink sm:text-[1.75rem]">
				{footerContent.brand}
			</p>

			<nav class="mt-10" aria-label="Footer links">
				<ul class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
					{
						footerContent.links.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-[0.72rem] font-medium tracking-[0.25em] text-muted/75 hover:text-ink/80"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<p class="mt-10 text-[0.68rem] font-medium tracking-[0.16em] text-muted/35">
				{footerContent.copyright}
			</p>
			<p class="mt-5 text-[0.82rem] font-medium tracking-[0.16em] text-muted/45">
				{footerContent.signature} <span class="text-gold">*</span>
			</p>
		</div>
	</Container>
</footer>
