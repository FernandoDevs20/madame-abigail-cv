---
import Container from "../ui/Container.astro";
import { contactContent } from "../../data/contact";
---

<section id="contacto" class="bg-bg pb-20 pt-16 sm:pb-24 sm:pt-20 lg:pb-28 lg:pt-24 bg-white" data-reveal="up">
	<Container class="lg:px-12 xl:px-16">
		<div class="mx-auto max-w-[62rem]">
			<header class="text-center">
				<p class="text-[0.62rem] font-medium tracking-[0.35em] text-gold sm:text-[0.68rem]">
					{contactContent.eyebrow}
				</p>
				<h2 class="mt-4 text-[2rem] leading-none text-ink sm:text-[2.45rem]">{contactContent.title}</h2>
				<p class="mx-auto mt-6 max-w-[44rem] text-[0.95rem] leading-relaxed text-muted sm:text-[1rem]">
					{contactContent.description}
				</p>
			</header>

			<form class="mt-12 space-y-8 sm:mt-14 sm:space-y-10">
				<div class="grid gap-8 md:grid-cols-2 md:gap-10">
					<div class="space-y-3">
						<label for="contact-name" class="text-[0.62rem] font-medium tracking-[0.2em] text-muted/70 sm:text-[0.68rem]">
							{contactContent.labels.name}
						</label>
						<input
							id="contact-name"
							name="name"
							type="text"
							placeholder={contactContent.placeholders.name}
							required
							class="h-12 w-full border-b border-border bg-transparent text-[1.05rem] text-ink outline-none placeholder:text-muted/30 focus-visible:border-ink sm:h-14 sm:text-[1.2rem]"
						/>
					</div>

					<div class="space-y-3">
						<label for="contact-email" class="text-[0.62rem] font-medium tracking-[0.2em] text-muted/70 sm:text-[0.68rem]">
							{contactContent.labels.email}
						</label>
						<input
							id="contact-email"
							name="email"
							type="email"
							placeholder={contactContent.placeholders.email}
							required
							class="h-12 w-full border-b border-border bg-transparent text-[1.05rem] text-ink outline-none placeholder:text-muted/30 focus-visible:border-ink sm:h-14 sm:text-[1.2rem]"
						/>
					</div>

					<div class="space-y-3 md:col-span-2">
						<label for="contact-phone" class="text-[0.62rem] font-medium tracking-[0.2em] text-muted/70 sm:text-[0.68rem]">
							{contactContent.labels.phone}
						</label>
						<input
							id="contact-phone"
							name="phone"
							type="tel"
							inputmode="tel"
							placeholder={contactContent.placeholders.phone}
							required
							class="h-12 w-full border-b border-border bg-transparent text-[1.05rem] text-ink outline-none placeholder:text-muted/30 focus-visible:border-ink sm:h-14 sm:text-[1.2rem]"
						/>
					</div>
				</div>

				<div class="space-y-3">
					<label for="contact-interest" class="text-[0.62rem] font-medium tracking-[0.2em] text-muted/70 sm:text-[0.68rem]">
						{contactContent.labels.interest}
					</label>
					<select
						id="contact-interest"
						name="interest"
						required
							class="h-12 w-full border-b border-border bg-transparent text-[1.05rem] text-ink outline-none focus-visible:border-ink sm:h-14 sm:text-[1.2rem]"
					>
						<option value="" selected disabled>
							Seleccione una opcion
						</option>
						{
							contactContent.options.map((option) => (
								<option value={option}>{option}</option>
							))
						}
					</select>
				</div>

				<div class="space-y-3">
					<label for="contact-message" class="text-[0.62rem] font-medium tracking-[0.2em] text-muted/70 sm:text-[0.68rem]">
						{contactContent.labels.message}
					</label>
					<textarea
						id="contact-message"
						name="message"
						rows={3}
						placeholder={contactContent.placeholders.message}
						required
							class="min-h-20 w-full resize-none border-b border-border bg-transparent pb-3 text-[1.05rem] text-ink outline-none placeholder:text-muted/30 focus-visible:border-ink sm:min-h-24 sm:text-[1.2rem]"
					></textarea>
				</div>

				<button
					type="submit"
					class="flex min-h-14 w-full items-center justify-center bg-ink px-8 text-xs font-semibold tracking-[0.2em] text-surface transition-colors duration-200 hover:bg-ink/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
				>
					{contactContent.submitLabel}
				</button>
			</form>
		</div>
	</Container>
</section>
